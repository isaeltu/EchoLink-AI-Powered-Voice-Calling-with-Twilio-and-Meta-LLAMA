# Django
DJANGO_SECRET_KEY=change-me-to-something-random
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Local dev: your ngrok URL. Production (Railway): your deployed https URL.
BASE_URL=https://your-public-url

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Hugging Face Inference API (Meta Llama 3 8B Instruct by default)
HUGGINGFACE_TOKEN=your_huggingface_access_token
# HF_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct

# RestoPOS Supabase project -- same project/api_key the Gemini Live agent
# (ai-calling-agent) uses, so both can serve the same restaurant's real menu
# and submit orders through the same webhook.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
RESTAURANT_ID=00000000-0000-0000-0000-000000000000
RESTAURANT_NAME=Your Restaurant Name
ORDER_WEBHOOK_API_KEY=voice_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ORDER_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/voice-order-webhook

# Optional: Postgres connection string. Railway provides this automatically
# once a Postgres plugin is attached. Without it, falls back to SQLite (fine
# for local dev, NOT durable on Railway -- its filesystem is ephemeral).
# DATABASE_URL=postgres://user:password@host:port/dbname
